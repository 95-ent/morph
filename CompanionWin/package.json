{
  "name": "water-morph-helper",
  "version": "1.0.0",
  "description": "Water Morph companion — Windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "ai.95ent.watermorph.helper",
    "productName": "Water Morph",
    "publish": null,
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "artifactName": "Water_Morph_1.0.0_Windows.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "runAfterFinish": true,
      "createStartMenuShortcut": true,
      "include": "installer.nsh"
    },
    "files": ["main.js", "preload.js"],
    "extraResources": [
      { "from": "vst3/Morph.vst3", "to": "Morph.vst3", "filter": ["**/*"] }
    ]
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  }
}
